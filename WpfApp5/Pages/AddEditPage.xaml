<Page x:Class="WpfApp5.Pages.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp5.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="AddEditPage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Артикул</TextBlock>
                <TextBox Text="{Binding Article}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Наименование</TextBlock>
                <TextBox Text="{Binding Name}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Ед. измерения</TextBlock>
                <ComboBox x:Name="UnitCb" Text="{Binding Unit}"></ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Цена</TextBlock>
                <TextBox x:Name="PriceCb" Text="{Binding Price}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Поставщик</TextBlock>
                <ComboBox x:Name="SupplierCb" Text="{Binding Supplier}"></ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Производитель</TextBlock>
                <ComboBox x:Name="ManufactCb" Text="{Binding Manufacturer}"></ComboBox>

            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Категория</TextBlock>
                <ComboBox x:Name="CategoryCb" Text="{Binding Category}"></ComboBox>

            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Скидка</TextBlock>
                <TextBox Text="{Binding Discount}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Количетсво</TextBlock>
                <TextBox Text="{Binding Coast}"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Описание</TextBlock>
                <TextBox Text="{Binding Description}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="SaveBtn" Click="SaveBtn_Click">Сохранить</Button>
                <Button x:Name="CanselBtn" Click="CanselBtn_Click">Отмена</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
